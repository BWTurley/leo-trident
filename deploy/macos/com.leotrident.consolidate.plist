<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.leotrident.consolidate</string>
  <key>ProgramArguments</key>
  <array>
    <string>REPLACE_HOME/leo_trident/.venv/bin/python</string>
    <string>REPLACE_HOME/leo_trident/scripts/consolidate.py</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>LEO_TRIDENT_HOME</key><string>REPLACE_HOME/leo_trident</string>
    <key>LEO_LLM_MODE</key><string>local</string>
    <key>LEO_EMBED_DEVICE</key><string>mps</string>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/bin:/bin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>2</integer>
    <key>Minute</key><integer>0</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>REPLACE_HOME/leo_trident/data/consolidate.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>REPLACE_HOME/leo_trident/data/consolidate.stderr.log</string>
  <key>WorkingDirectory</key>
  <string>REPLACE_HOME/leo_trident</string>
  <key>RunAtLoad</key><false/>
</dict>
</plist>
