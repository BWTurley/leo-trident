# Copy to .env and edit for your environment.
# All values optional — defaults fall back to Abacus behavior.

LEO_TRIDENT_HOME=~/leo_trident
LEO_LLM_MODE=local
LEO_EMBED_DEVICE=mps

OLLAMA_URL=http://localhost:11434
LEO_CONSOLIDATION_MODEL=qwen2.5:14b-instruct-q5_K_M
LEO_EMBED_MODEL=nomic-embed-text

# Only used if LEO_LLM_MODE=cloud
ABACUS_API_KEY=
ABACUS_ENDPOINT=https://routellm.abacus.ai/v1
ABACUS_MODEL=claude-sonnet-4-6
